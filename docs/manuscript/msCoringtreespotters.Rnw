tab <- xtable(
  spptable,
  align = c(
    "l",
    "p{7cm}",
    "p{5cm}",
    "p{3cm}",
    "r"
  ),
  caption = paste0(
    "Treespotters species grouped by tree type, growth speed, and wood anatomy. We collected the growth speed information for each species from \\cite{burns_silvics_1990}",
    "We sampled a total of ", n_total, " individual trees"
  ),
  label = "tab:tsCount"
)

print(
  tab,
  include.rownames = FALSE,
  include.colnames = FALSE,
  add.to.row = header,
  sanitize.text.function = identity,
  hline.after = c(-1, nrow(spptable)),
  caption.placement = "top"
)
@

