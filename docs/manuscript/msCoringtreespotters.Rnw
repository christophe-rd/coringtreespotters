ayear_df2_EOS  <- read.csv("/Users/christophe_rouleau-desrochers/github/coringtreespotters/analyses/output/GM_EOSparam_ayear.csv")

bspp_df2_GDD$spp_name  <- empts$latbi[match(bspp_df2_GDD$spp, empts$spp_num)]
aspp_df2_GDD$spp_name  <- empts$latbi[match(aspp_df2_GDD$spp, empts$spp_num)]

ayear_df2_GDD$year_name <- empts$year[match(ayear_df2_GDD$year, empts$year_num)]
ayear_df2_GSL$year_name <- empts$year[match(ayear_df2_GSL$year, empts$year_num)]
ayear_df2_SOS$year_name <- empts$year[match(ayear_df2_SOS$year, empts$year_num)]
ayear_df2_EOS$year_name <- empts$year[match(ayear_df2_EOS$year, empts$year_num)]

# Reorder years
ayear_df2_GDD <- ayear_df2_GDD[order(ayear_df2_GDD$year_name),]
ayear_df2_GSL <- ayear_df2_GSL[order(ayear_df2_GSL$year_name),]
ayear_df2_SOS <- ayear_df2_SOS[order(ayear_df2_SOS$year_name),]
ayear_df2_EOS <- ayear_df2_EOS[order(ayear_df2_EOS$year_name),]

fmt <- function(df) sprintf("%.2f [%.2f, %.2f]", df$mean, df$p5, df$p95)

param_labels <- c(
  "$\\alpha$",
  "$\\sigma_{\\alpha_{tree}}$", "$\\sigma_{y}$",
  paste0("$\\beta_{spp_{",   bspp_df2_GDD$spp_name,  "}}$"),
  paste0("$\\alpha_{year_{", ayear_df2_GDD$year_name, "}}$"),
  paste0("$\\alpha_{spp_{",  aspp_df2_GDD$spp_name,  "}}$")
)

combined <- data.frame(
  "Parameter" = param_labels,
  "GDD" = c(fmt(a_df2_GDD), fmt(sigma_df2_GDD), fmt(bspp_df2_GDD), fmt(aspp_df2_GDD), fmt(ayear_df2_GDD)),
  "GSL" = c(fmt(a_df2_GSL), fmt(sigma_df2_GSL), fmt(bspp_df2_GSL), fmt(aspp_df2_GSL), fmt(ayear_df2_GSL)),
  "SOS" = c(fmt(a_df2_SOS), fmt(sigma_df2_SOS), fmt(bspp_df2_SOS), fmt(aspp_df2_SOS), fmt(ayear_df2_SOS)),
  "EOS" = c(fmt(a_df2_EOS), fmt(sigma_df2_EOS), fmt(bspp_df2_EOS), fmt(aspp_df2_EOS), fmt(ayear_df2_EOS)),
  check.names = FALSE
)

print(xtable(combined,
             caption = "Summary output of each parameter from our four predictors, using ring width (on the log scale) as the reponse variable. We report estimates as mean and 90\\% uncertainty intervals (in square brackets) across our four different predictors (GDD: growing degree days, GSL: growing season length, SOS: start of season and EOS: end of season). See data analyses section for more details.",
             label = "tab:tab_all"),
      include.rownames = FALSE, sanitize.text.function = identity, caption.placement = "top")
@

<<Table combined previous year model, results='asis', echo = FALSE>>=
options(digits = 2)

a_df2      <- read.csv("/Users/christophe_rouleau-desrochers/github/coringtreespotters/analyses/output/GM_GDDparam_a_prvsYr.csv")
sigma_df2  <- read.csv("/Users/christophe_rouleau-desrochers/github/coringtreespotters/analyses/output/GM_GDDparam_sigma_prvsYr.csv")
bspp_df2   <- read.csv("/Users/christophe_rouleau-desrochers/github/coringtreespotters/analyses/output/GM_GDDparam_bspp_prvsYr.csv")
bspp_df2Yr <- read.csv("/Users/christophe_rouleau-desrochers/github/coringtreespotters/analyses/output/GM_GDDparam_bsppYr_prvsYr.csv")
aspp_df2   <- read.csv("/Users/christophe_rouleau-desrochers/github/coringtreespotters/analyses/output/GM_GDDparam_aspp_prvsYr.csv")
ayear_df2  <- read.csv("/Users/christophe_rouleau-desrochers/github/coringtreespotters/analyses/output/GM_GDDparam_ayear_prvsYr.csv")

bspp_df2$spp_name  <- empts$latbi[match(bspp_df2$spp, empts$spp_num)]
bspp_df2Yr$spp_name  <- empts$latbi[match(bspp_df2Yr$spp, empts$spp_num)]
aspp_df2$spp_name  <- empts$latbi[match(aspp_df2$spp, empts$spp_num)]
ayear_df2$year_name <- empts$year[match(ayear_df2$year, empts$year_num)]

# Reorder years
ayear_df2 <- ayear_df2[order(ayear_df2$year_name),]

fmt <- function(df) sprintf("%.2f [%.2f, %.2f]", df$mean, df$p5, df$p95)

param_labels <- c(
  "$\\alpha$",
  "$\\sigma_{\\alpha_{tree}}$", "$\\sigma_{y}$",
  paste0("$\\beta_{\\text{species}_{", bspp_df2$spp_name,   "}}^{\\text{current}}$"),
  paste0("$\\beta_{\\text{species}_{", bspp_df2Yr$spp_name, "}}^{\\text{previous}}$"),
  paste0("$\\alpha_{\\text{year}_{",   ayear_df2$year_name, "}}$"),
  paste0("$\\alpha_{\\text{spp}_{",    aspp_df2$spp_name,   "}}$")
)

combined <- data.frame(
  "Parameter" = param_labels,
  "Estimate" = c(fmt(a_df2), fmt(sigma_df2), fmt(bspp_df2), fmt(bspp_df2Yr), fmt(aspp_df2), fmt(ayear_df2)),
  check.names = FALSE
)

print(xtable(combined,
             caption = "Summary output of each parameter from the previous year model using ring width (on the log scale) as the reponse variable. We report estimates as mean and 90\\% uncertainty intervals (in square brackets). See data analyses section for more details.",
             label = "tab:tab_PrvsYr"),
      include.rownames = FALSE, sanitize.text.function = identity, caption.placement = "top")
@

