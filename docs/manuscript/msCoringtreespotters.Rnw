aspp_df2   <- read.csv("/Users/christophe_rouleau-desrochers/github/coringtreespotters/analyses/output/GM_GDDparam_aspp_prvsYr.csv")
ayear_df2  <- read.csv("/Users/christophe_rouleau-desrochers/github/coringtreespotters/analyses/output/GM_GDDparam_ayear_prvsYr.csv")

bspp_df2$spp_name  <- empts$latbi[match(bspp_df2$spp, empts$spp_num)]
bspp_df2Yr$spp_name  <- empts$latbi[match(bspp_df2Yr$spp, empts$spp_num)]
